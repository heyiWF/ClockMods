			"type": "shell",
			"command": ".\\gradlew.bat",
			"args": [
				"--stop",
				";",
				"$env:JAVA_HOME='C:\\Program Files\\Android\\Android Studio\\jbr'",
				";",
				".\\gradlew.bat",
				"--no-daemon",
				"--console=plain",

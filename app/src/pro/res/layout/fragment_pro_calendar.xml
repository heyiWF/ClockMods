<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="20dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_previous"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/calendar_previous_month"
            app:icon="@drawable/ic_chevron_left"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <TextView
            android:id="@+id/calendar_month_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceTitleLarge" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_today"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/calendar_today" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_next"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/calendar_next_month"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

    </LinearLayout>

    <GridLayout
        android:id="@+id/calendar_weekdays"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:columnCount="7"
        android:rowCount="1" />

    <GridLayout
        android:id="@+id/calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="7"
        android:rowCount="6" />

</LinearLayout>